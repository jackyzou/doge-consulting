// Doge Consulting – full business management schema
// SQLite for local-first operation

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────
// Auth & Users
// ──────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @default("") // empty for Google-only users
  googleId     String?  @unique       // Google OAuth sub claim
  name         String
  role         String   @default("user") // "admin" | "user"
  phone        String?
  company      String?
  language     String   @default("en") // "en" | "zh-CN" | "zh-TW" | "es" | "fr"
  avatarUrl    String?                 // Google profile picture
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  orders   Order[]
  quotes   Quote[]
  payments Payment[]
}

// ──────────────────────────────────────────
// Product Catalog
// ──────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // "furniture", "electronics", "home-goods", etc.
  sku         String   @unique
  unitPrice   Float    // USD
  unit        String   @default("piece") // "piece", "set", "kg", "cbm"
  lengthCm    Float?
  widthCm     Float?
  heightCm    Float?
  weightKg    Float?
  imageUrl    String?
  linkUrl     String?  // external product link (e.g. supplier page)
  isActive    Boolean  @default(true)
  isCatalog   Boolean  @default(false) // show on public catalog page
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quoteItems QuoteItem[]
  orderItems OrderItem[]
}

// ──────────────────────────────────────────
// Quotes / Purchase Orders
// ──────────────────────────────────────────
model Quote {
  id             String   @id @default(cuid())
  quoteNumber    String   @unique // "QT-2026-0001"
  status         String   @default("draft") // draft, sent, accepted, rejected, expired, converted
  
  // Customer info
  customerId     String?
  customer       User?    @relation(fields: [customerId], references: [id])
  customerName   String
  customerEmail  String
  customerPhone  String?
  customerCompany String?

  // Financials
  subtotal       Float    @default(0)
  shippingCost   Float    @default(0)
  insuranceCost  Float    @default(0)
  customsDuty    Float    @default(0)
  discount       Float    @default(0)
  taxAmount      Float    @default(0)
  totalAmount    Float    @default(0)
  currency       String   @default("USD")
  depositPercent Float    @default(70)

  // Shipping details
  shippingMethod String?  // "LCL", "FCL_20GP", "FCL_40GP", "FCL_40HC"
  originCity     String   @default("Shenzhen")
  destinationCity String  @default("Seattle, WA")
  estimatedTransit String?

  notes          String?
  snapshotUrl    String?   // 3D visualizer screenshot (base64 data URL or file path)
  validUntil     DateTime?
  sentAt         DateTime?
  acceptedAt     DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  items          QuoteItem[]
  order          Order?     // quote → order conversion
  paymentLink    PaymentLink?
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  
  name        String
  description String?
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float
  unit        String  @default("piece")
  lengthCm    Float?
  widthCm     Float?
  heightCm    Float?
  weightKg    Float?
}

// ──────────────────────────────────────────
// Orders
// ──────────────────────────────────────────
model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique // "ORD-2026-0001"
  status       String   @default("pending") // pending, confirmed, sourcing, packing, in_transit, customs, delivered, closed, cancelled

  // Link to quote
  quoteId      String?  @unique
  quote        Quote?   @relation(fields: [quoteId], references: [id])

  // Customer
  customerId   String?
  customer     User?    @relation(fields: [customerId], references: [id])
  customerName String
  customerEmail String
  customerPhone String?

  // Financials
  subtotal     Float    @default(0)
  shippingCost Float    @default(0)
  insuranceCost Float   @default(0)
  customsDuty  Float    @default(0)
  discount     Float    @default(0)
  taxAmount    Float    @default(0)
  totalAmount  Float    @default(0)
  depositAmount Float   @default(0)
  balanceDue   Float    @default(0)
  currency     String   @default("USD")

  // Shipping
  shippingMethod String?
  originCity     String  @default("Shenzhen")
  destinationCity String @default("Seattle, WA")
  trackingId     String?
  vessel         String?
  estimatedDelivery DateTime?

  notes          String?
  closedAt       DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  items          OrderItem[]
  payments       Payment[]
  statusHistory  OrderStatusHistory[]
  documents      Document[]
  shipments      Shipment[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  name        String
  description String?
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float
  unit        String  @default("piece")
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  changedBy String?  // admin user name
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────
// Payments
// ──────────────────────────────────────────
model Payment {
  id              String   @id @default(cuid())
  paymentNumber   String   @unique // "PAY-2026-0001"
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  customerId      String?
  customer        User?    @relation(fields: [customerId], references: [id])

  amount          Float
  currency        String   @default("USD")
  method          String   // "credit_card", "debit_card", "ach", "wire"
  status          String   @default("pending") // pending, processing, completed, failed, refunded
  type            String   @default("deposit") // "deposit", "balance", "full"

  // External payment reference
  externalId      String?  // Airwallex payment intent ID
  externalUrl     String?  // Airwallex checkout URL
  
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentLink     PaymentLink?
}

model PaymentLink {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid()) // public URL token
  quoteId     String?  @unique
  quote       Quote?   @relation(fields: [quoteId], references: [id])
  paymentId   String?  @unique
  payment     Payment? @relation(fields: [paymentId], references: [id])

  amount      Float
  currency    String   @default("USD")
  description String?
  status      String   @default("active") // active, used, expired
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ──────────────────────────────────────────
// Documents (invoices, receipts, POs)
// ──────────────────────────────────────────
model Document {
  id           String   @id @default(cuid())
  documentNumber String @unique // "INV-2026-0001", "REC-2026-0001", "PO-2026-0001"
  type         String   // "invoice", "receipt", "purchase_order", "proforma"
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])

  // Stored as JSON string
  data         String   // JSON blob with full document data
  pdfPath      String?  // relative path to generated PDF

  issuedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ──────────────────────────────────────────
// Email Log
// ──────────────────────────────────────────
model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  type      String   // "quote_sent", "order_confirmed", "payment_received", "order_closed", "payment_link"
  status    String   @default("sent") // "sent", "failed"
  orderId   String?
  error     String?
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────
// App Settings (key-value store)
// ──────────────────────────────────────────
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────
// Newsletter Subscribers
// ──────────────────────────────────────────
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  language  String   @default("en") // "en" | "zh-CN" | "zh-TW" | "es" | "fr"
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────
// Blog Posts (admin-managed CMS)
// ──────────────────────────────────────────
model BlogPost {
  id         String   @id @default(cuid())
  slug       String
  language   String   @default("en") // "en" | "zh-CN" | "zh-TW" | "es" | "fr"
  title      String
  excerpt    String
  content    String   // markdown
  category   String
  emoji      String   @default("\uD83D\uDCE6")
  published  Boolean  @default(false)
  authorName String   @default("Doge Consulting Team")
  readTime   String   @default("5 min")
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([slug, language])
}

// ──────────────────────────────────────────
// Coupons / Promo Codes
// ──────────────────────────────────────────
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique           // "WELCOME15", "SHIP2026"
  description    String?
  discountType   String    @default("percentage") // "percentage" | "fixed"
  discountValue  Float                       // 15 = 15% or $15
  minOrderAmount Float?                      // minimum order to qualify
  maxDiscount    Float?                      // cap for percentage discounts
  maxUses        Int?                        // null = unlimited
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  validFrom      DateTime  @default(now())
  validUntil     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  usages         CouponUsage[]
}

model CouponUsage {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id])
  orderId     String?
  quoteId     String?
  email       String                         // customer email
  discount    Float                          // actual $ amount deducted
  createdAt   DateTime @default(now())

  @@unique([couponId, email])                // one use per email per coupon
}

// ──────────────────────────────────────────
// Page View Analytics
// ──────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  path      String                          // "/catalog", "/blog/xyz"
  referrer  String?                         // document.referrer or Referer header
  userAgent String?
  country   String?                         // from CF-IPCountry or geo lookup
  region    String?                         // state/province
  city      String?
  language  String?                         // Accept-Language
  sessionId String?                         // anonymous session cookie
  userId    String?                         // if logged in
  deviceType String?                        // "desktop" | "mobile" | "tablet"
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([country])
}

// ──────────────────────────────────────────
// Vessel & Shipment Tracking
// ──────────────────────────────────────────
model Vessel {
  id         String   @id @default(cuid())
  name       String                        // "EVER GIVEN"
  imo        String?  @unique              // IMO number (7 digits)
  mmsi       String?  @unique              // MMSI for AIS tracking
  flag       String?                       // Country code "PA", "LR", "HK"
  carrier    String?                       // "COSCO", "Maersk", "Evergreen"
  vesselType String   @default("container") // container, bulk, tanker, roro
  callSign   String?
  lengthM    Float?                        // overall length in meters
  widthM     Float?                        // beam in meters
  yearBuilt  Int?
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  shipments  Shipment[]
}

model Shipment {
  id              String   @id @default(cuid())
  containerNumber String?                  // e.g. "CSLU6543210"
  containerType   String   @default("40HC") // 20GP, 40GP, 40HC, 45HC, 20RF, 40RF
  sealNumber      String?

  // Voyage info
  vesselId        String?
  vessel          Vessel?  @relation(fields: [vesselId], references: [id])
  voyageNumber    String?                  // "0W1E5S1MA"
  billOfLading    String?                  // B/L number

  // Route
  portOfLoading   String   @default("Shenzhen (CNSZX)")
  portOfDischarge String   @default("Seattle (USSEA)")
  placeOfReceipt  String?                  // factory / warehouse pickup
  placeOfDelivery String?                  // final destination

  // Dates
  etd             DateTime?                // estimated departure
  atd             DateTime?                // actual departure
  eta             DateTime?                // estimated arrival
  ata             DateTime?                // actual arrival

  // Status
  status          String   @default("booked") // booked, loaded, in_transit, transshipment, arriving, discharged, customs, delivered

  // Weight / measurement
  grossWeightKg   Float?
  volumeCbm       Float?

  // Order link
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id])

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  events          ShipmentEvent[]

  @@index([containerNumber])
  @@index([billOfLading])
  @@index([status])
  @@index([orderId])
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  location    String                       // "Yantian, China" or UN/LOCODE
  status      String                       // "gate_in", "loaded", "departed", "arrived", "discharged", "customs_hold", "released", "delivered"
  description String?                      // free-text detail
  timestamp   DateTime                     // when this event occurred
  source      String   @default("manual")  // "manual", "api", "carrier_webhook"

  createdAt   DateTime @default(now())

  @@index([shipmentId])
  @@index([timestamp])
}

// ──────────────────────────────────────────
// Product Match Queries (AI Sourcing)
// ──────────────────────────────────────────
model ProductMatchQuery {
  id             String   @id @default(cuid())
  sourceUrl      String?                    // URL to the original US listing
  imageData      String?                    // base64 image (max ~2MB)
  description    String?                    // user description of what they want
  sourcePrice    Float?                     // price the user saw on the US listing
  estimatedPrice Float?                     // our instant 20%-off estimate
  category       String?                    // furniture, electronics, etc.
  status         String   @default("pending") // pending, quoted, contacted, closed
  adminNotes     String?
  quotedPrice    Float?                     // admin's real sourced price
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  userId         String?                    // if logged in

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ──────────────────────────────────────────
// Contact Form Inquiries (CRM)
// ──────────────────────────────────────────
model ContactInquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  countryCode String?                      // "+1", "+86", "+852", etc.
  subject     String
  message     String
  status      String   @default("new")     // new, contacted, qualified, closed
  adminNotes  String?
  source      String   @default("contact_form") // contact_form, quote, catalog_match
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// ──────────────────────────────────────────
// Core Web Vitals
// ──────────────────────────────────────────
model WebVital {
  id         String   @id @default(cuid())
  name       String   // LCP, CLS, INP, TTFB, FCP
  value      Float
  rating     String   // good, needs-improvement, poor
  path       String
  deviceType String?  // desktop, mobile, tablet
  createdAt  DateTime @default(now())

  @@index([name])
  @@index([createdAt])
  @@index([path])
}

// ──────────────────────────────────────────
// Agent Fleet — Decision & Activity Logs
// ──────────────────────────────────────────
model AgentLog {
  id          String   @id @default(cuid())
  agent       String                       // "alex", "amy", "seth", "rachel", "seto"
  type        String   @default("note")    // decision, action, report, alert, meeting, kpi
  priority    String   @default("normal")  // low, normal, high, critical
  title       String
  content     String                       // full log content (markdown)
  tags        String?                      // comma-separated: "revenue,pricing,q2"
  status      String   @default("open")    // open, in_progress, completed, escalated
  assignedTo  String?                      // agent name or "jacky" for CEO escalation
  relatedTo   String?                      // reference: "meeting:2026-03-09", "kpi:dau", etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agent])
  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

// ──────────────────────────────────────────
// Agent Fleet — Chat Threads & Messages
// ──────────────────────────────────────────
model ChatThread {
  id            String   @id @default(cuid())
  title         String                       // auto-generated from first message
  triggerType   String   @default("user_message") // "user_message", "standup", "decision", "onboarding"
  participants  String   @default("")        // comma-separated agent IDs
  relatedId     String?                      // link to decision ID, standup date, etc.
  status        String   @default("active")  // "active", "resolved", "archived"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      ChatMessage[]

  @@index([status])
  @@index([createdAt])
  @@index([triggerType])
}

model ChatMessage {
  id          String      @id @default(cuid())
  threadId    String
  thread      ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parentId    String?                        // reply to specific message (optional)
  sender      String                         // "jacky", "alex", "amy", "seth", "rachel", "seto", "tiffany", "system"
  content     String                         // markdown content
  mentions    String?                        // comma-separated: "seth,rachel"
  attachments String?                        // JSON array of file paths
  metadata    String?                        // JSON: CLI output, code refs, decisions made
  status      String   @default("delivered") // "pending_response", "delivered", "thinking", "error"
  createdAt   DateTime @default(now())

  @@index([threadId])
  @@index([sender])
  @@index([createdAt])
  @@index([status])
}
